{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/scan",
      "destination": "/api/scan"
    },
    {
      "source": "/api/delivery_scan",
      "destination": "/api/delivery_scan"
    }
  ]
}
